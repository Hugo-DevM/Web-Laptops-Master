---
import styles from "../styles/components/footer.module.css";
---

<footer class={styles.footer}>
  <div class={styles.footerContent}>
    <div class={styles.footerTop}>
      <!-- Brand -->
      <div class={styles.footerBrand}>
        <a class={styles.logo} href="/"
          >Laptops <span class={styles.logoSpan}>Master</span></a
        >
        <p class={styles.brandDesc}>
          Reparación profesional de laptops y equipos de cómputo en Ciudad de
          México. Diagnóstico gratuito y garantía en todos nuestros servicios.
        </p>
        <div class={styles.socials}>
          <a
            href="https://www.facebook.com/share/18sHGGv6BZ/?mibextid=wwXIfr"
            target="_blank"
            rel="noopener noreferrer"
            class={styles.socialLink}
            aria-label="Facebook"
          >
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"
              ></path>
            </svg>
          </a>
          <a
            href="https://www.instagram.com/laptopsmaster1?igsh=d3A2bWgxazVsa3ln"
            class={styles.socialLink}
            aria-label="Instagram"
          >
            <svg
              width="18"
              height="18"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <circle cx="12" cy="12" r="4"></circle>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"
              ></circle>
            </svg>
          </a>
          <a
            href="https://www.tiktok.com/@laptopsmasterofic"
            target="_blank"
            rel="noopener noreferrer"
            class={styles.socialLink}
            aria-label="TikTok"
          >
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"
              ></path>
            </svg>
          </a>
          <a
            href="https://wa.me/523221481334"
            target="_blank"
            rel="noopener noreferrer"
            class={styles.socialLink}
            aria-label="WhatsApp"
          >
            <svg
              width="18"
              height="18"
              fill="currentColor"
              viewBox="0 0 360 362"
            >
              <path
                fill-rule="evenodd"
                d="M307.546 52.566C273.709 18.684 228.706.017 180.756 0 81.951 0 1.538 80.404 1.504 179.235c-.017 31.594 8.242 62.432 23.928 89.609L0 361.736l95.024-24.925c26.179 14.285 55.659 21.805 85.655 21.814h.077c98.788 0 179.21-80.413 179.244-179.244.017-47.898-18.608-92.926-52.454-126.807v-.008Zm-126.79 275.788h-.06c-26.73-.008-52.952-7.194-75.831-20.765l-5.44-3.231-56.391 14.791 15.05-54.981-3.542-5.638c-14.912-23.721-22.793-51.139-22.776-79.286.035-82.14 66.867-148.973 149.051-148.973 39.793.017 77.198 15.53 105.328 43.695 28.131 28.157 43.61 65.596 43.593 105.398-.035 82.149-66.867 148.982-148.982 148.982v.008Zm81.719-111.577c-4.478-2.243-26.497-13.073-30.606-14.568-4.108-1.496-7.09-2.243-10.073 2.243-2.982 4.487-11.568 14.577-14.181 17.559-2.613 2.991-5.226 3.361-9.704 1.117-4.477-2.243-18.908-6.97-36.02-22.226-13.313-11.878-22.304-26.54-24.916-31.027-2.613-4.486-.275-6.91 1.959-9.136 2.011-2.011 4.478-5.234 6.721-7.847 2.244-2.613 2.983-4.486 4.478-7.469 1.496-2.991.748-5.603-.369-7.847-1.118-2.243-10.073-24.289-13.812-33.253-3.636-8.732-7.331-7.546-10.073-7.692-2.613-.13-5.595-.155-8.586-.155-2.991 0-7.839 1.118-11.947 5.604-4.108 4.486-15.677 15.324-15.677 37.361s16.047 43.344 18.29 46.335c2.243 2.991 31.585 48.225 76.51 67.632 10.684 4.615 19.029 7.374 25.535 9.437 10.727 3.412 20.49 2.931 28.208 1.779 8.604-1.289 26.498-10.838 30.228-21.298 3.73-10.46 3.73-19.433 2.613-21.298-1.117-1.865-4.108-2.991-8.586-5.234l.008-.017Z"
                clip-rule="evenodd"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Nav links -->
      <div class={styles.footerLinks}>
        <div class={styles.footerCol}>
          <h4 class={styles.colTitle}>Servicios</h4>
          <ul class={styles.colList}>
            <li>
              <a href="#servicios" class={styles.colLink}
                >Reparación de pantalla</a
              >
            </li>
            <li>
              <a href="#servicios" class={styles.colLink}>Cambio de batería</a>
            </li>
            <li>
              <a href="#servicios" class={styles.colLink}>Limpieza interna</a>
            </li>
            <li>
              <a href="#servicios" class={styles.colLink}
                >Reinstalación de software</a
              >
            </li>
            <li>
              <a href="#servicios" class={styles.colLink}
                >Reparación de MacBook</a
              >
            </li>
          </ul>
        </div>

        <div class={styles.footerCol}>
          <h4 class={styles.colTitle}>Empresa</h4>
          <ul class={styles.colList}>
            <li>
              <a href="#nosotros" class={styles.colLink}>¿Por qué nosotros?</a>
            </li>
            <li>
              <a href="#proceso" class={styles.colLink}>Nuestro proceso</a>
            </li>
            <li>
              <a href="#testimonios" class={styles.colLink}>Testimonios</a>
            </li>
            <li>
              <a href="#faq" class={styles.colLink}>Preguntas frecuentes</a>
            </li>
          </ul>
        </div>

        <div class={styles.footerCol}>
          <h4 class={styles.colTitle}>Contacto</h4>
          <ul class={styles.colList}>
            <li class={styles.colItem}>
              <svg
                width="14"
                height="14"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                ></path>
              </svg>
              +52 322 148 1334
            </li>
            <li class={styles.colItem}>
              <svg
                width="14"
                height="14"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                ></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              Colonia Pitillal, Puerto Vallarta
            </li>
            <li class={styles.colItem}>
              <svg
                width="14"
                height="14"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
              Lun – Viernes, 9:00 – 20:00 Sabado, 9:00 – 17:00
            </li>
          </ul>
        </div>
      </div>
    </div>

    <div class={styles.footerBottom}>
      <p class={styles.copyright}>
        &copy; {new Date().getFullYear()} Laptops Master. Todos los derechos reservados.
      </p>
      <p class={styles.credits}>
        Hecho con
        <svg
          width="14"
          height="14"
          fill="currentColor"
          viewBox="0 0 24 24"
          style="color: var(--color-secondary); display:inline-block; vertical-align:middle; margin: 0 2px;"
        >
          <path
            d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"
          ></path>
        </svg>
        por HAMCSoft
      </p>
    </div>
  </div>
</footer>
