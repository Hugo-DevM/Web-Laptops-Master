---
import styles from "../styles/sections/contact.module.css";
---

<section class={styles.contact} id="contacto">
  <div class={styles.contactContent}>
    <div class={styles.contactHeader}>
      <span class={styles.contactSpan}>CONTÁCTANOS</span>
      <h2 class={styles.contactTitle}>Estamos listos para ayudarte</h2>
      <p class={styles.contactDescription}>
        Cuéntanos qué le pasa a tu equipo. Respondemos rápido y te damos
        solución.
      </p>
    </div>

    <div class={styles.contactGrid}>
      <!-- Left: Contact info -->
      <div class={styles.contactInfo}>
        <a
          href="https://wa.me/523221481334?text=Hola%20Laptops%20Master%2C%20me%20gustar%C3%ADa%20solicitar%20una%20revisi%C3%B3n%20o%20reparaci%C3%B3n%20de%20mi%20equipo.%20%C2%BFMe%20pueden%20dar%20informaci%C3%B3n%20sobre%20el%20servicio%2C%20tiempos%20y%20costos%3F"
          target="_blank"
          rel="noopener noreferrer"
          class={styles.whatsappBtn}
        >
          <span class={styles.whatsappIcon}>
            <svg width="24" height="24" fill="none" viewBox="0 0 360 362">
              <path
                fill="#fff"
                fill-rule="evenodd"
                d="M307.546 52.566C273.709 18.684 228.706.017 180.756 0 81.951 0 1.538 80.404 1.504 179.235c-.017 31.594 8.242 62.432 23.928 89.609L0 361.736l95.024-24.925c26.179 14.285 55.659 21.805 85.655 21.814h.077c98.788 0 179.21-80.413 179.244-179.244.017-47.898-18.608-92.926-52.454-126.807v-.008Zm-126.79 275.788h-.06c-26.73-.008-52.952-7.194-75.831-20.765l-5.44-3.231-56.391 14.791 15.05-54.981-3.542-5.638c-14.912-23.721-22.793-51.139-22.776-79.286.035-82.14 66.867-148.973 149.051-148.973 39.793.017 77.198 15.53 105.328 43.695 28.131 28.157 43.61 65.596 43.593 105.398-.035 82.149-66.867 148.982-148.982 148.982v.008Zm81.719-111.577c-4.478-2.243-26.497-13.073-30.606-14.568-4.108-1.496-7.09-2.243-10.073 2.243-2.982 4.487-11.568 14.577-14.181 17.559-2.613 2.991-5.226 3.361-9.704 1.117-4.477-2.243-18.908-6.97-36.02-22.226-13.313-11.878-22.304-26.54-24.916-31.027-2.613-4.486-.275-6.91 1.959-9.136 2.011-2.011 4.478-5.234 6.721-7.847 2.244-2.613 2.983-4.486 4.478-7.469 1.496-2.991.748-5.603-.369-7.847-1.118-2.243-10.073-24.289-13.812-33.253-3.636-8.732-7.331-7.546-10.073-7.692-2.613-.13-5.595-.155-8.586-.155-2.991 0-7.839 1.118-11.947 5.604-4.108 4.486-15.677 15.324-15.677 37.361s16.047 43.344 18.29 46.335c2.243 2.991 31.585 48.225 76.51 67.632 10.684 4.615 19.029 7.374 25.535 9.437 10.727 3.412 20.49 2.931 28.208 1.779 8.604-1.289 26.498-10.838 30.228-21.298 3.73-10.46 3.73-19.433 2.613-21.298-1.117-1.865-4.108-2.991-8.586-5.234l.008-.017Z"
                clip-rule="evenodd"></path>
            </svg>
          </span>
          <div>
            <p class={styles.whatsappLabel}>¿Respuesta Inmediata?</p>
            <p class={styles.whatsappText}>Escríbenos por WhatsApp</p>
          </div>
        </a>

        <div class={styles.infoCards}>
          <div class={styles.infoCard}>
            <span class={styles.infoIcon}>
              <svg
                width="20"
                height="20"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                ></path>
              </svg>
            </span>
            <div>
              <p class={styles.infoLabel}>TELÉFONO</p>
              <p class={styles.infoValue}>+52 3221481334</p>
            </div>
          </div>

          <div class={styles.infoCard}>
            <span class={styles.infoIcon}>
              <svg
                width="20"
                height="20"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                ></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </span>
            <div>
              <p class={styles.infoLabel}>UBICACIÓN</p>
              <p class={styles.infoValue}>Colonia Pitillal, Puerto Vallarta</p>
            </div>
          </div>

          <div class={styles.infoCard}>
            <span class={styles.infoIcon}>
              <svg
                width="20"
                height="20"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
            </span>
            <div>
              <p class={styles.infoLabel}>HORARIO DE ATENCIÓN</p>
              <p class={styles.infoValue}>Lunes a Sábado de 9:00 a 20:00 hrs</p>
            </div>
          </div>
        </div>

        <p class={styles.responseNote}>
          <svg
            width="16"
            height="16"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          Respondemos en menos de <strong>1 hora</strong> en <a
            class={styles.responseNoteLink}>horario de atención.</a
          >
        </p>
      </div>

      <!-- Right: Form -->
      <div class={styles.formCard}>
        <form class={styles.form}>
          <div class={styles.formGroup}>
            <label class={styles.formLabel}
              >Tu nombre <span class={styles.required}>*</span></label
            >
            <input
              type="text"
              class={styles.formInput}
              placeholder="Hugo Armando"
              required
            />
          </div>

          <div class={styles.formGroup}>
            <label class={styles.formLabel}
              >Marca y modelo <span class={styles.required}>*</span></label
            >
            <input
              type="text"
              id="modelo"
              class={styles.formInput}
              placeholder="Ej. HP Pavilion 15, Dell Inspiron, MacBook Pro 2020"
              required
            />
          </div>

          <div class={styles.formGroup}>
            <label class={styles.formLabel}
              >Tipo de equipo <span class={styles.required}>*</span></label
            >
            <div class={styles.selectWrapper}>
              <select class={styles.formSelect} required>
                <option value="" disabled selected>Selecciona una opción</option
                >
                <option value="laptop">Laptop</option>
                <option value="mac">MacBook / Mac</option>
                <option value="pc">PC de escritorio</option>
                <option value="tablet">Tablet</option>
                <option value="otro">Otro</option>
              </select>
              <span class={styles.selectArrow}>
                <svg
                  width="16"
                  height="16"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M19 9l-7 7-7-7"></path>
                </svg>
              </span>
            </div>
          </div>

          <div class={styles.formGroup}>
            <label class={styles.formLabel}
              >¿Qué le pasa a tu equipo? <span class={styles.required}>*</span
              ></label
            >
            <textarea
              class={styles.formTextarea}
              placeholder="Descríbenos el problema..."
              rows={4}
              required></textarea>
          </div>

          <button type="submit" class={styles.submitBtn}>
            Enviar por WhatsApp
          </button>

          <p class={styles.privacyNote}>
            Al enviar este formulario aceptas que nos pongamos en contacto
            contigo para darte información sobre tu solicitud.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.querySelector("#contacto form") as HTMLFormElement;

  form?.addEventListener("submit", (e) => {
    e.preventDefault();

    const nombre = (
      form.querySelector('input[type="text"]') as HTMLInputElement
    )?.value.trim();
    const modelo = (
      form.querySelector("#modelo") as HTMLInputElement
    )?.value.trim();
    const equipo = (form.querySelector("select") as HTMLSelectElement)?.value;
    const problema = (
      form.querySelector("textarea") as HTMLTextAreaElement
    )?.value.trim();

    const equipoLabel: Record<string, string> = {
      laptop: "Laptop",
      mac: "MacBook / Mac",
      pc: "PC de escritorio",
      tablet: "Tablet",
      otro: "Otro",
    };

    const mensaje =
      `*[ NUEVA SOLICITUD DE SERVICIO ]*\n` +
      `_Laptops Master - Solicitud desde la web_\n` +
      `--------------------------------\n` +
      `*Nombre:* ${nombre}\n` +
      `*Tipo de equipo:* ${equipoLabel[equipo] ?? equipo}\n` +
      `*Marca y modelo:* ${modelo}\n` +
      `*Problema:* ${problema}\n` +
      `--------------------------------\n` +
      `_Por favor responde a la brevedad._`;

    const url = `https://wa.me/523221481334?text=${encodeURIComponent(mensaje)}`;
    window.open(url, "_blank", "noopener,noreferrer");
    form.reset();
  });
</script>
